generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int       @id @default(autoincrement())
  nickname  String
  email     String    @unique
  password  String?
  createdAt DateTime  @default(now())
  image     String?
  name      String?
  expenses  Expense[]
  logs      Log[]
}

model Expense {
  id            Int          @id @default(autoincrement())
  descricao     String
  responsavel   String
  real          Float
  previsto      Float?       @default(0)
  vencimento    DateTime
  status        String
  userId        Int
  typeId        Int?
  statusId      Int?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  parcelaAtual  Int?         @default(1)
  totalParcelas Int?         @default(1)
  user          User         @relation(fields: [userId], references: [id])
  type          ExpenseType? @relation(fields: [typeId], references: [id])
  statusRef     Status?      @relation(fields: [statusId], references: [id])
}

model ExpenseType {
  id          Int       @id @default(autoincrement())
  name        String
  categoryId  Int?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  expenses    Expense[]
  categoryRef Category? @relation(fields: [categoryId], references: [id])
}

model Category {
  id        Int           @id @default(autoincrement())
  name      String        @unique
  icon      String?
  color     String?
  createdAt DateTime      @default(now())
  types     ExpenseType[]
}

model Status {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  color     String?
  createdAt DateTime  @default(now())
  expenses  Expense[]
}

model Log {
  id        Int      @id @default(autoincrement())
  action    String
  details   String
  userId    Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}
